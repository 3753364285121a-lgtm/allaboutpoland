    bg: 'bg-blue-100 dark:bg-blue-900/30',
    fg: 'text-blue-600 dark:text-blue-400',
  },
  zus: {
    path: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    bg: 'bg-purple-100 dark:bg-purple-900/30',
    fg: 'text-purple-600 dark:text-purple-400',
  },
  docs: {
    path: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    bg: 'bg-emerald-100 dark:bg-emerald-900/30',
    fg: 'text-emerald-600 dark:text-emerald-400',
  },
  legalization: {
    path: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
    bg: 'bg-rose-100 dark:bg-rose-900/30',
    fg: 'text-rose-600 dark:text-rose-400',
  },
  growth: {
    path: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
    bg: 'bg-teal-100 dark:bg-teal-900/30',
    fg: 'text-teal-600 dark:text-teal-400',
  },
  tools: {
    path: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z',

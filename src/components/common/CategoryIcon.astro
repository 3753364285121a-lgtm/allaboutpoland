};

const icon = icons[slug] || icons.tools;
---

<div class={`${className} ${icon.bg} rounded-xl flex items-center justify-center shrink-0`}>
  <svg class={`w-5 h-5 ${icon.fg}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d={icon.path} />
  </svg>
</div>

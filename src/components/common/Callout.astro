---
interface Props {
  type?: 'info' | 'warning' | 'success' | 'danger';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info: {
    bg: 'bg-accent-50 dark:bg-accent-900/20',
    border: 'border-accent-400',
    icon: 'text-accent-600 dark:text-accent-400',
    title: 'text-accent-800 dark:text-accent-300',
  },
  warning: {
    bg: 'bg-amber-50 dark:bg-amber-900/20',
    border: 'border-amber-400',
    icon: 'text-amber-600 dark:text-amber-400',
    title: 'text-amber-800 dark:text-amber-300',
  },
  success: {
    bg: 'bg-green-50 dark:bg-green-900/20',
    border: 'border-green-400',
    icon: 'text-green-600 dark:text-green-400',
    title: 'text-green-800 dark:text-green-300',
  },
  danger: {
    bg: 'bg-red-50 dark:bg-red-900/20',
    border: 'border-red-400',
    icon: 'text-red-600 dark:text-red-400',
    title: 'text-red-800 dark:text-red-300',
  },
};

const icons = {
  info: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  warning: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
  success: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  danger: 'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z',
};

const s = styles[type];
---

<div class={`${s.bg} border-l-4 ${s.border} rounded-r-lg p-4 my-6`} role="alert">
  <div class="flex gap-3">
    <svg class={`w-5 h-5 mt-0.5 shrink-0 ${s.icon}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[type]} />
    </svg>
    <div>
      {title && <p class={`font-semibold mb-1 ${s.title}`}>{title}</p>}
      <div class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>

---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/content/Breadcrumbs.astro';
import TableOfContents from '../components/content/TableOfContents.astro';
import AuthorBox from '../components/content/AuthorBox.astro';
import { generateArticleSchema } from '../utils/seo';
import { categories } from '../data/navigation';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    category: string;
    author: string;
    reviewedBy?: string;
    datePublished: string;
    dateModified?: string;
    timeToRead?: number;
    tags?: string[];
    ogImage?: string;
  };
  headings: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings } = Astro.props;

const categoryData = categories.find((c) => c.slug === frontmatter.category);
const categoryName = categoryData?.name || frontmatter.category;

const breadcrumbs = [
  { name: 'Гайды', url: '/guides' },
  { name: categoryName, url: `/guides/${frontmatter.category}` },
  { name: frontmatter.title, url: Astro.url.pathname },
];

const articleSchema = generateArticleSchema({
  title: frontmatter.title,
  description: frontmatter.description,
  url: Astro.url.pathname,
  image: frontmatter.ogImage,
  datePublished: frontmatter.datePublished,
  dateModified: frontmatter.dateModified || frontmatter.datePublished,
  author: frontmatter.author,
});

const seo = {
  title: frontmatter.title,
  description: frontmatter.description,
  ogType: 'article' as const,
  ogImage: frontmatter.ogImage,
  article: {
    publishedTime: frontmatter.datePublished,
    modifiedTime: frontmatter.dateModified || frontmatter.datePublished,
    author: frontmatter.author,
    section: categoryName,
    tags: frontmatter.tags,
  },
};
---

<BaseLayout seo={seo} schema={articleSchema}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-10">
      <!-- Main content -->
      <article class="min-w-0">
        <header class="mb-8">
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-4">
            {frontmatter.title}
          </h1>
          <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
            {frontmatter.description}
          </p>
        </header>

        <AuthorBox
          author={frontmatter.author}
          reviewedBy={frontmatter.reviewedBy}
          datePublished={frontmatter.datePublished}
          dateModified={frontmatter.dateModified}
          timeToRead={frontmatter.timeToRead}
        />

        <div class="prose dark:prose-invert">
          <slot />
        </div>
      </article>

      <!-- Sidebar (desktop only) -->
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />

          <!-- Related category links -->
          {categoryData?.children && (
            <div class="mt-6 bg-gray-50 dark:bg-gray-800 rounded-xl p-5 border border-gray-200 dark:border-gray-700">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wide mb-3">
                {categoryData.icon} {categoryName}
              </h3>
              <ul class="space-y-2 text-sm">
                {categoryData.children.map((child) => (
                  <li>
                    <a
                      href={`/guides/${frontmatter.category}/${child.slug}`}
                      class="text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
                    >
                      {child.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </aside>
    </div>

    <!-- Mobile TOC (shown above content on small screens) -->
    <div class="lg:hidden mt-6">
      <TableOfContents headings={headings} />
    </div>
  </div>
</BaseLayout>

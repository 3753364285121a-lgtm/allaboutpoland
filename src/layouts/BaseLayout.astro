---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { getPageTitle, getCanonicalURL, getOGImageURL, type SEOProps } from '../utils/seo';

interface Props {
  seo: SEOProps;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { seo, schema } = Astro.props;

const title = getPageTitle(seo.title);
const canonical = seo.canonical ? getCanonicalURL(seo.canonical) : getCanonicalURL(Astro.url.pathname);
const ogImage = getOGImageURL(seo.ogImage);
const ogType = seo.ogType || 'website';
const robots = seo.noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1';
---

<!doctype html>
<html lang="ru" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={seo.description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta name="author" content={seo.article?.author || 'All About Poland'} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="All About Poland" />
    <meta property="og:locale" content="ru_RU" />

    {seo.article?.publishedTime && (
      <meta property="article:published_time" content={seo.article.publishedTime} />
    )}
    {seo.article?.modifiedTime && (
      <meta property="article:modified_time" content={seo.article.modifiedTime} />
    )}
    {seo.article?.author && (
      <meta property="article:author" content={seo.article.author} />
    )}
    {seo.article?.section && (
      <meta property="article:section" content={seo.article.section} />
    )}
    {seo.article?.tags?.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="ru" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Structured Data -->
    {schema && (
      Array.isArray(schema)
        ? schema.map((s) => (
            <script type="application/ld+json" set:html={JSON.stringify(s)} />
          ))
        : <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Dark mode (prevent FOUC) -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 transition-colors">
    <a href="#main-content" class="skip-to-content">Перейти к содержимому</a>
    <Header />
    <main id="main-content" role="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

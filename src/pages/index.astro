---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/content/GuideCard.astro';
import CategoryIcon from '../components/common/CategoryIcon.astro';
import { categories } from '../data/navigation';
import { generateWebsiteSchema, generateOrganizationSchema } from '../utils/seo';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const featuredGuides = allGuides
  .filter((g) => g.data.featured)
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime())
  .slice(0, 6);

const latestGuides = allGuides
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime())
  .slice(0, 6);

const guidesToShow = featuredGuides.length > 0 ? featuredGuides : latestGuides;

const seo = {
  title: 'Бизнес в Польше — блог бухгалтера',
  description: 'Блог практикующего бухгалтера о бизнесе в Польше. JDG, налоги, ZUS, карта побыту — без воды, с реальными цифрами и пошаговыми инструкциями.',
  canonical: '/',
};

const schema = [generateWebsiteSchema(), generateOrganizationSchema()];
---

<BaseLayout seo={seo} schema={schema}>
  <!-- Hero — personal, warm -->
  <section class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="max-w-3xl">
        <p class="text-amber-400 font-medium mb-3 text-sm tracking-wide uppercase">Блог практикующего бухгалтера</p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-5">
          Бизнес в Польше —<br />
          <span class="text-amber-300">без воды и паники</span>
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-2xl">
          Открыть JDG, разобраться с ZUS, выбрать налоговый режим, получить карту побыту.
          Пишу так, как объясняю своим клиентам — просто, с цифрами и примерами.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/guides/registration/jdg-open"
            class="px-6 py-3 bg-amber-500 text-slate-900 font-semibold rounded-lg hover:bg-amber-400 transition-colors"
          >
            Открыть JDG — гайд
          </a>
          <a
            href="/tools/salary-calculator"
            class="px-6 py-3 bg-slate-700 text-white font-semibold rounded-lg border border-slate-600 hover:bg-slate-600 transition-colors"
          >
            Калькулятор зарплаты
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Personal intro strip -->
  <section class="bg-amber-50 dark:bg-amber-900/10 border-b border-amber-100 dark:border-amber-900/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed text-center">
        Привет! Я веду бухгалтерию для 50+ предпринимателей в Польше.
        Здесь делюсь тем, что реально работает — без копипаста из законов, человеческим языком.
      </p>
    </div>
  </section>

  <!-- Topics Grid — allaboutberlin style -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-10 text-center">
      О чём пишу
    </h2>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {categories.filter(c => c.slug !== 'tools' && c.slug !== 'closing').map((cat) => (
        <a
          href={`/guides#${cat.slug}`}
          class="group flex flex-col items-center text-center p-6 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 hover:shadow-lg hover:border-gray-300 dark:hover:border-gray-500 transition-all duration-200"
        >
          <div class="text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors mb-3">
            <CategoryIcon slug={cat.slug} size="lg" />
          </div>
          <span class="text-sm font-medium text-gray-800 dark:text-gray-200 group-hover:text-gray-900 dark:group-hover:text-white transition-colors">
            {cat.name}
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest / Featured articles -->
  {guidesToShow.length > 0 && (
    <section class="bg-gray-50 dark:bg-gray-800/50 py-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">
              Свежие статьи
            </h2>
            <p class="text-gray-500 dark:text-gray-400 text-sm">
              Начните с этих — самые полезные
            </p>
          </div>
          <a
            href="/guides"
            class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-amber-600 dark:text-amber-400 hover:text-amber-700 transition-colors"
          >
            Все статьи
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {guidesToShow.map((guide) => {
            const catData = categories.find((c) => c.slug === guide.data.category);
            return (
              <GuideCard
                title={guide.data.title}
                description={guide.data.description}
                href={`/guides/${guide.id}`}
                category={catData?.name}
                timeToRead={guide.data.timeToRead}
                datePublished={guide.data.datePublished}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter — personal tone -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="bg-slate-900 dark:bg-slate-800 rounded-2xl p-8 sm:p-12 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">
        Новые ставки ZUS? Изменения в налогах?
      </h2>
      <p class="text-slate-400 mb-6 max-w-lg mx-auto text-sm leading-relaxed">
        Подпишитесь — присылаю только когда есть что-то важное.
        Без спама, 1-2 письма в месяц.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="Ваш email"
          class="flex-1 px-4 py-3 rounded-lg border border-slate-700 bg-slate-800 text-white placeholder-slate-500 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none"
          required
        />
        <button
          type="submit"
          class="px-6 py-3 bg-amber-500 text-slate-900 font-semibold rounded-lg hover:bg-amber-400 transition-colors"
        >
          Подписаться
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

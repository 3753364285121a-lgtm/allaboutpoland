---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/content/GuideCard.astro';
import { categories } from '../data/navigation';
import { generateWebsiteSchema, generateOrganizationSchema } from '../utils/seo';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const featuredGuides = allGuides
  .filter((g) => g.data.featured)
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime())
  .slice(0, 6);

const latestGuides = allGuides
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime())
  .slice(0, 6);

const guidesToShow = featuredGuides.length > 0 ? featuredGuides : latestGuides;

const seo = {
  title: 'All About Poland',
  description: 'Информационный портал о жизни в Польше для русскоязычных. Гайды по визам, работе, жилью, документам, финансам и бизнесу.',
  canonical: '/',
};

const schema = [generateWebsiteSchema(), generateOrganizationSchema()];
---

<BaseLayout seo={seo} schema={schema}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary-600 via-primary-700 to-primary-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Всё о жизни<br />в
          <span class="text-primary-200">Польше</span>
        </h1>
        <p class="text-lg sm:text-xl text-primary-100 leading-relaxed mb-8 max-w-2xl">
          Подробные гайды, калькуляторы и шаблоны документов для тех, кто переезжает или уже живёт в Польше.
          На русском языке.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/guides"
            class="px-6 py-3 bg-white text-primary-700 font-semibold rounded-lg hover:bg-primary-50 transition-colors"
          >
            Смотреть гайды
          </a>
          <a
            href="/guides/visa/relocating"
            class="px-6 py-3 bg-primary-500/30 text-white font-semibold rounded-lg border border-primary-400/40 hover:bg-primary-500/50 transition-colors"
          >
            Переезд в Польшу
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-2">
      Разделы
    </h2>
    <p class="text-gray-600 dark:text-gray-400 mb-8">
      Выберите тему, которая вас интересует
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map((cat) => (
        <a
          href={`/guides/${cat.slug}`}
          class="group flex items-start gap-4 p-5 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 hover:shadow-lg hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-200"
        >
          <span class="text-3xl shrink-0" role="img" aria-hidden="true">{cat.icon}</span>
          <div>
            <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
              {cat.name}
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 leading-relaxed">
              {cat.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Guides -->
  {guidesToShow.length > 0 && (
    <section class="bg-gray-50 dark:bg-gray-800/50 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-2">
              Популярные гайды
            </h2>
            <p class="text-gray-600 dark:text-gray-400">
              Самые полезные материалы для начала
            </p>
          </div>
          <a
            href="/guides"
            class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 transition-colors"
          >
            Все гайды
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {guidesToShow.map((guide) => {
            const catData = categories.find((c) => c.slug === guide.data.category);
            return (
              <GuideCard
                title={guide.data.title}
                description={guide.data.description}
                href={`/guides/${guide.id}`}
                category={catData?.name}
                timeToRead={guide.data.timeToRead}
                datePublished={guide.data.datePublished}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- CTA / Newsletter -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-primary-50 dark:bg-primary-900/20 rounded-2xl p-8 sm:p-12 text-center border border-primary-100 dark:border-primary-800/40">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-3">
        Не пропустите новые гайды
      </h2>
      <p class="text-gray-600 dark:text-gray-400 mb-6 max-w-lg mx-auto">
        Подпишитесь на рассылку и получайте уведомления о новых статьях и обновлениях.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          placeholder="Ваш email"
          class="flex-1 px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none"
          required
        />
        <button
          type="submit"
          class="px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors"
        >
          Подписаться
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

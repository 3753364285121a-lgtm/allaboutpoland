---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Страница не найдена',
  description: 'Запрашиваемая страница не существует.',
  noindex: true,
};
---

<BaseLayout seo={seo}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-6xl font-bold text-primary-600 dark:text-primary-400 mb-4">404</p>
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-4">
      Страница не найдена
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
      Возможно, страница была перемещена или удалена. Попробуйте начать с главной.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors"
      >
        На главную
      </a>
      <a
        href="/guides"
        class="px-6 py-3 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 font-semibold rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
      >
        Все гайды
      </a>
    </div>
  </div>
</BaseLayout>

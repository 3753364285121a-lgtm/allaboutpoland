---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Поиск',
  description: 'Поиск по гайдам и статьям на All About Poland.',
  canonical: '/search',
  noindex: true,
};
---

<BaseLayout seo={seo}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">Поиск</h1>

    <div class="mb-8">
      <input
        type="search"
        id="search-input"
        placeholder="Введите запрос..."
        class="w-full px-4 py-3 text-lg rounded-xl border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none"
        autofocus
      />
    </div>

    <div id="search-results" class="space-y-4">
      <p class="text-gray-500 dark:text-gray-400">
        Начните вводить запрос для поиска по гайдам, статьям и глоссарию.
      </p>
    </div>
  </div>
</BaseLayout>

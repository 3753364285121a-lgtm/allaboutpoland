---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/content/Breadcrumbs.astro';
import SalaryCalculator from '../../components/tools/SalaryCalculator.vue';
import { generateFAQSchema } from '../../utils/seo';

const seo = {
  title: 'Калькулятор зарплаты в Польше 2026 (brutto → netto)',
  description: 'Калькулятор зарплаты brutto netto Польша 2026. Рассчитайте netto из brutto с учётом ZUS, PIT, umowa o pracę, zlecenie, dzieło, B2B и PPK.',
  canonical: '/tools/salary-calculator',
};

const breadcrumbs = [
  { name: 'Инструменты', url: '/tools' },
  { name: 'Калькулятор зарплаты', url: '/tools/salary-calculator' },
];

const faqItems = [
  { question: 'Как рассчитать netto из brutto в Польше?', answer: 'Из brutto вычитаются взносы ZUS работника (13.71%), взнос на здравоохранение (9% от суммы после ZUS), налог PIT (12% или 32%) и PPK (если подключены). Остаток — это netto, сумма «на руки».' },
  { question: 'Сколько netto с 5000 brutto в Польше?', answer: 'При umowa o pracę с зарплатой 5 000 zł brutto вы получите примерно 3 660 zł netto (при стандартных условиях, без PPK, возраст старше 26 лет).' },
  { question: 'Сколько netto с 7000 brutto?', answer: 'При umowa o pracę с 7 000 zł brutto — примерно 5 060 zł netto. С льготой до 26 лет — около 5 500 zł netto.' },
  { question: 'Сколько netto с 10000 brutto в Польше?', answer: 'При umowa o pracę с 10 000 zł brutto — примерно 7 140 zł netto. Точная сумма зависит от возраста, PPK и налогового порога.' },
  { question: 'Сколько netto с 15000 brutto?', answer: 'При 15 000 zł brutto по umowa o pracę — примерно 10 530 zł netto. Если годовой доход превысит 120 000 zł, ставка PIT вырастет с 12% до 32%.' },
  { question: 'Сколько netto с 20000 brutto в Польше?', answer: 'При 20 000 zł brutto — примерно 14 100 zł netto по umowa o pracę. Часть дохода будет облагаться ставкой 32%.' },
  { question: 'Чем отличается brutto от netto в Польше?', answer: 'Brutto — зарплата до вычетов (указывается в договоре). Netto — сумма, которую вы получаете на руки после вычета ZUS, здравоохранения и налога PIT.' },
  { question: 'Какая минимальная зарплата в Польше в 2026 году?', answer: 'Минимальная зарплата brutto в Польше в 2026 году составляет 4 666 zł. Netto — примерно 3 400 zł.' },
  { question: 'Сколько ZUS платит работник в Польше?', answer: 'Работник платит 13.71% от brutto: пенсионный взнос (emerytalne) 9.76%, по инвалидности (rentowe) 1.5%, по болезни (chorobowe) 2.45%.' },
  { question: 'Что такое PPK и сколько вычитают?', answer: 'PPK (Pracownicze Plany Kapitałowe) — пенсионная программа. Работник платит 2% от brutto, работодатель — 1.5%. Можно отказаться.' },
  { question: 'Платят ли налог PIT до 26 лет в Польше?', answer: 'Нет. Работники до 26 лет освобождены от PIT на доходы до 85 528 zł в год (ulga dla młodych). Это увеличивает netto на 500-1500 zł в месяц.' },
  { question: 'Как считается зарплата на umowa zlecenie?', answer: 'На umowa zlecenie вычитаются те же взносы ZUS (кроме chorobowe — оно добровольное) и PIT 12%. Netto обычно чуть выше, чем на umowa o pracę.' },
  { question: 'Сколько получу на руки на umowa o dzieło?', answer: 'На umowa o dzieło нет взносов ZUS. Вычитается только PIT 12% от 80% суммы (20% — koszty uzyskania przychodu). Netto составляет около 90.4% от brutto.' },
  { question: 'Сколько стоит работник для работодателя в Польше?', answer: 'Работодатель платит дополнительно ~20% сверх brutto: ZUS работодателя (emerytalne 9.76%, rentowe 6.5%, wypadkowe ~1.67%), Fundusz Pracy (2.45%), FGŚP (0.1%) и PPK (1.5%).' },
  { question: 'Kalkulator wynagrodzeń 2026 — где рассчитать?', answer: 'Используйте наш калькулятор на этой странице. Он учитывает все ставки ZUS и PIT на 2026 год, 4 типа договоров и льготу до 26 лет.' },
];

const faqSchema = generateFAQSchema(faqItems);
---

<BaseLayout seo={seo} schema={faqSchema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-3">
        Калькулятор зарплаты в Польше 2026
      </h1>
      <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
        Рассчитайте сколько вы получите «на руки» (netto) из зарплаты brutto.
        Учитывает взносы ZUS, налог PIT, тип договора и PPK. Актуальные ставки 2026 года.
      </p>
    </header>

    <SalaryCalculator client:load />

    <div class="prose dark:prose-invert mt-12 max-w-2xl mx-auto">
      <h2>Как считается зарплата brutto netto в Польше</h2>
      <p>
        В Польше зарплата всегда указывается в <strong>brutto</strong> (до вычетов).
        Из неё вычитаются:
      </p>
      <ol>
        <li><strong>Взносы ZUS работника</strong> — пенсионный (9.76%), по инвалидности (1.5%), по болезни (2.45%) = итого 13.71%</li>
        <li><strong>Взнос на здравоохранение (składka zdrowotna)</strong> — 9% от суммы после ZUS</li>
        <li><strong>Налог PIT</strong> — 12% (до 120 000 PLN/год) или 32% (свыше). Необлагаемый минимум — 30 000 PLN</li>
        <li><strong>PPK</strong> (если подключены) — 2% от brutto</li>
      </ol>

      <h2>Примеры расчёта netto 2026</h2>

      <table>
        <thead>
          <tr><th>Brutto (zł)</th><th>Netto umowa o pracę</th><th>Netto zlecenie</th><th>Netto o dzieło</th></tr>
        </thead>
        <tbody>
          <tr><td>4 666 (мин.)</td><td>~3 400</td><td>~3 510</td><td>~4 220</td></tr>
          <tr><td>5 000</td><td>~3 660</td><td>~3 760</td><td>~4 520</td></tr>
          <tr><td>7 000</td><td>~5 060</td><td>~5 200</td><td>~6 330</td></tr>
          <tr><td>10 000</td><td>~7 140</td><td>~7 340</td><td>~9 040</td></tr>
          <tr><td>12 000</td><td>~8 530</td><td>~8 770</td><td>~10 850</td></tr>
          <tr><td>15 000</td><td>~10 530</td><td>~10 830</td><td>~13 560</td></tr>
          <tr><td>20 000</td><td>~14 100</td><td>~14 350</td><td>~18 080</td></tr>
        </tbody>
      </table>
      <p><em>* Расчёт приблизительный. Без PPK, возраст старше 26 лет, стандартные koszty.</em></p>

      <h2>Льгота для молодых до 26 лет (ulga dla młodych)</h2>
      <p>
        Работники до 26 лет освобождены от налога PIT на доходы до 85 528 PLN в год.
        Это увеличивает зарплату netto на 500–1 500 zł в месяц в зависимости от суммы brutto.
      </p>

      <h2>Сколько платит работодатель сверх brutto</h2>
      <p>
        Работодатель дополнительно платит ~20% сверх вашей зарплаты brutto:
      </p>
      <ul>
        <li>ZUS emerytalne — 9.76%</li>
        <li>ZUS rentowe — 6.5%</li>
        <li>ZUS wypadkowe — ~1.67%</li>
        <li>Fundusz Pracy — 2.45%</li>
        <li>FGŚP — 0.1%</li>
        <li>PPK работодателя — 1.5% (если подключен)</li>
      </ul>
      <p>
        То есть работник с brutto 10 000 zł обходится работодателю примерно в 12 100 zł.
      </p>

      <h2 id="faq">FAQ — частые вопросы о зарплате в Польше</h2>

      {faqItems.map((item) => (
        <Fragment>
          <h3>{item.question}</h3>
          <p>{item.answer}</p>
        </Fragment>
      ))}
    </div>
  </div>
</BaseLayout>
